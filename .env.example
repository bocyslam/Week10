# n8n Environment Configuration Template
# Copy this file to .env.local and fill in actual values
# .env.local is excluded from version control for security

NODE_ENV=development

# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=n8n

# n8n Database Connection
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=your_secure_password_here

# n8n Encryption Key (REQUIRED - generate via: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your_generated_hex_key_here

# n8n UI Configuration
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=0.0.0.0

# Disable telemetry for development
N8N_DIAGNOSTICS_ENABLED=false
